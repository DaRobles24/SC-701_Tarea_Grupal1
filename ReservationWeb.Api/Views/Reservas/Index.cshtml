@model IEnumerable<ReservationWeb.Mvc.Models.ReservationListViewModel>
@{
    ViewData["Title"] = "Reservas Médicas";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-calendar-heart-fill"></i> Reservas Médicas
        </h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nueva Reserva
        </a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-4">
            <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
            No hay reservas registradas.
            <a asp-action="Create" class="alert-link ms-1">¡Crea la primera!</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>#</th>
                            <th><i class="bi bi-person-fill"></i> Paciente</th>
                            <th><i class="bi bi-person-badge-fill"></i> Médico</th>
                            <th><i class="bi bi-heart-pulse-fill"></i> Especialidad</th>
                            <th><i class="bi bi-calendar3"></i> Fecha Cita</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted small">@item.Id</td>
                                <td class="fw-semibold">@item.Paciente</td>
                                <td>@item.Medico</td>
                                <td>
                                    <span class="badge bg-primary rounded-pill">@item.Especialidad</span>
                                </td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-info me-1" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning me-1" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <p class="text-muted small mt-2">Total: @Model.Count() reservas</p>
    }
</div>

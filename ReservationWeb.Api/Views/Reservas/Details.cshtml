@model ReservationWeb.Mvc.Models.ReservationListViewModel
@{
    ViewData["Title"] = "Detalle de Reserva";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-eye"></i> Detalle de Reserva #@Model.Id</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-5 text-muted"><i class="bi bi-person"></i> Paciente</dt>
                        <dd class="col-sm-7 fw-semibold">@Model.Paciente</dd>

                        <dt class="col-sm-5 text-muted"><i class="bi bi-person-badge"></i> Médico</dt>
                        <dd class="col-sm-7">@Model.Medico</dd>

                        <dt class="col-sm-5 text-muted"><i class="bi bi-heart-pulse"></i> Especialidad</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-primary rounded-pill fs-6">@Model.Especialidad</span>
                        </dd>

                        <dt class="col-sm-5 text-muted"><i class="bi bi-calendar3"></i> Fecha de Cita</dt>
                        <dd class="col-sm-7">
                            @Model.Fecha.ToString("dddd dd 'de' MMMM yyyy - HH:mm",
                                new System.Globalization.CultureInfo("es-CR"))
                        </dd>

                        <dt class="col-sm-5 text-muted"><i class="bi bi-clock-history"></i> Creada el</dt>
                        <dd class="col-sm-7 text-muted small">
                            @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                        </dd>
                    </dl>
                </div>
                <div class="card-footer d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Eliminar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

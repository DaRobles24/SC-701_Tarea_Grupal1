<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Reservas Médicas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        body { background-color: #f5f7fa; }
        .navbar-brand { font-weight: 700; letter-spacing: .5px; }
        .card { border-radius: 12px; }
        .card-header { border-radius: 12px 12px 0 0 !important; }
        .table thead th { font-size: .82rem; text-transform: uppercase; letter-spacing: .05em; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Reservas" asp-action="Index">
                <i class="bi bi-hospital-fill"></i> Reservas Médicas
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Reservas" asp-action="Index">
                            <i class="bi bi-list-ul"></i> Ver Reservas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Reservas" asp-action="Create">
                            <i class="bi bi-plus-circle"></i> Nueva Reserva
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="pb-5">
        @RenderBody()
    </main>

    <footer class="text-center text-muted py-3 border-top small">
        &copy; @DateTime.Now.Year – Sistema de Reservas Médicas | SC-701
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
